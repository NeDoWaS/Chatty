<Window x:Class="Chatty.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chatty"
        xmlns:viewmodel="clr-namespace:ChattyClient.MVM.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="470" Width="820">
    <Window.DataContext>
        <viewmodel:MainViewModel />
    </Window.DataContext>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.4*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <DockPanel>
            <TextBox Height="25" 
                     DockPanel.Dock="Top"
                     Text="{Binding Username}"/>
            <Button Height="25" 
                    DockPanel.Dock="Top"
                    Content="Connect"
                    Command="{Binding ConnectToServerCommand, UpdateSourceTrigger=PropertyChanged}"/>
            <ListView/>
        </DockPanel>

        <StackPanel Grid.Column="1">
            <ListView Height="380"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Height="55"
                      Width="520"
                      VerticalAlignment="Center"/>
                <Button Width="55"
                        Content="Send"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
